_600x150.jpg.600x150_q95_crop_upscale.jpg","ams_acf":[],"_links":{"self":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events\/50145","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events"}],"about":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/types\/ajde_events"}],"author":[{"embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/comments?post=50145"}],"version-history":[{"count":3,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events\/50145\/revisions"}],"predecessor-version":[{"id":50974,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events\/50145\/revisions\/50974"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/media\/50973"}],"wp:attachment":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/media?parent=50145"}],"wp:term":[{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/tags?post=50145"},{"taxonomy":"event_type","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type?post=50145"},{"taxonomy":"event_type_2","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_2?post=50145"},{"taxonomy":"event_type_3","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_3?post=50145"},{"taxonomy":"event_type_4","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_4?post=50145"},{"taxonomy":"event_type_5","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_5?post=50145"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}