-1.jpg","ams_acf":[],"_links":{"self":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events\/50434","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events"}],"about":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/types\/ajde_events"}],"author":[{"embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/comments?post=50434"}],"version-history":[{"count":1,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events\/50434\/revisions"}],"predecessor-version":[{"id":50436,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/ajde_events\/50434\/revisions\/50436"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/media\/50435"}],"wp:attachment":[{"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/media?parent=50434"}],"wp:term":[{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/tags?post=50434"},{"taxonomy":"event_type","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type?post=50434"},{"taxonomy":"event_type_2","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_2?post=50434"},{"taxonomy":"event_type_3","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_3?post=50434"},{"taxonomy":"event_type_4","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_4?post=50434"},{"taxonomy":"event_type_5","embeddable":true,"href":"https:\/\/www.portugalrunning.com\/wp-json\/wp\/v2\/event_type_5?post=50434"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}